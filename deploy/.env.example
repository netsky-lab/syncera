# Copy to .env and fill in. .env is gitignored.

# ---- Web UI auth ----
# HTTP Basic Auth — required in production. If unset, auth is disabled.
BASIC_AUTH_USER=research
BASIC_AUTH_PASS=change-me-to-a-long-random-string

# ---- LLM endpoint used by the research pipeline ----
# OpenAI-compatible base URL. On self-hosted Runpod this is the proxy URL.
GEMMA_BASE_URL=https://your-runpod-proxy.proxy.runpod.net/v1
GEMMA_MODEL=qwen3.6-35b-a3b
GEMMA_API_KEY=dummy

# ---- Pipeline container paths ----
# Host-side path to the repo root. The web container spawns pipeline
# containers via docker-out-of-docker; the bind-mount must be a HOST path.
PIPELINE_HOST_REPO_ROOT=/opt/research-lab
# Compose network the pipeline container attaches to — must match the
# docker-compose project network name (usually "<project>_default").
PIPELINE_NETWORK=deploy_default
