# Copy to deploy/.env and fill in. .env is gitignored.
# These values feed docker-compose.yml when bringing up the stack on a server.

# ---- Session cookie signing secret (REQUIRED in prod) ----
# 32+ random chars. Generate with:  openssl rand -hex 32
# If unset, middleware falls back to Basic Auth and sessions are disabled.
SESSION_SECRET=

# ---- Bootstrap admin (seeded into users.json on first start) ----
# Only used if the users store is empty. After the first signup creates an
# admin, these env vars are ignored. Leave blank to bootstrap via the UI.
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Optional production bootstrap token for first-admin signup via UI/API.
# If NODE_ENV=production and ADMIN_EMAIL/ADMIN_PASSWORD are not set, the
# first signup requires this value in body.bootstrap_token or X-Bootstrap-Token.
BOOTSTRAP_TOKEN=

# Open signup to anyone? Default 0 (closed — admins invite via /settings).
# When closed, the first user to sign up still becomes admin.
ALLOW_SIGNUP=0

# ---- Basic Auth fallback (legacy, pre-session-cookie migration) ----
# Middleware accepts Basic Auth on browser pages ONLY when SESSION_SECRET
# is unset. Set both if you want to bootstrap without signing up first.
BASIC_AUTH_USER=research
BASIC_AUTH_PASS=

# ---- API keys (comma-separated env seed) ----
# Bootstrap keys accepted on /api/* routes. Generate with:
#   openssl rand -hex 24
# Once an admin exists, prefer minting keys via the /settings UI — those
# are hashed on disk; env keys are cleartext and harder to rotate.
API_KEYS=

# ---- Public URL (for webhook artifact links) ----
# Embedded in webhook payload under `artifacts.*` so consumers can pull the
# report/facts/pdf straight from your instance. Must be reachable from
# consumer side — internal URLs won't work.
PUBLIC_URL=https://research.example.com
# Used by email verification/password-reset links. Usually same as PUBLIC_URL.
APP_BASE_URL=https://research.example.com

# ---- CORS + rate limit ----
# Empty = fail-closed. Pin to your consumer app origin(s) if exposing API cross-origin.
API_CORS_ORIGINS=
# Requests per minute per identity (API key or basic-auth credential).
API_RATE_LIMIT_PER_MIN=60

# ---- LLM endpoint used by pipelines spawned from the web container ----
# Choose one: qwen (self-hosted/OpenAI-compatible) or gemini.
LLM_PROVIDER=qwen
# Set to 0 for llama.cpp / Runpod proxies that break SSE streams.
LLM_STREAM=0
# Structured outputs always use OpenAI-compatible function/tool calling.

# Qwen/self-hosted provider. GEMMA_* is legacy fallback; prefer QWEN_*.
QWEN_BASE_URL=https://your-endpoint.proxy.runpod.net/v1
QWEN_MODEL=qwen3.6-35b-a3b
QWEN_API_KEY=dummy
GEMMA_BASE_URL=https://your-endpoint.proxy.runpod.net/v1
GEMMA_MODEL=qwen3.6-35b-a3b
GEMMA_API_KEY=dummy

# Gemini provider: OpenAI-compatible chat plus native Gemini tools.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_REASONING_EFFORT=low
GEMINI_SEARCH_GROUNDING=0
GEMINI_SEARCH_MAX_RESULTS=5
GEMINI_SEARCH_TIMEOUT_MS=20000

# Optional cost model override. Defaults: Gemini input=$0.50/1M,
# Gemini output=$3.00/1M, self-hosted Qwen=$0 unless overridden.
# LLM_INPUT_USD_PER_1M=0.5
# LLM_OUTPUT_USD_PER_1M=3

# Optional provider-aware concurrency overrides. Defaults:
# qwen: harvest=3 evidence=3 analyzer=4 relevance=5 verifier=5
# gemini: harvest=6 evidence=8 analyzer=8 relevance=12 verifier=12
# Recommended Qwen 16-slot / 64k profile:
# CONCURRENCY_HARVEST=10
# CONCURRENCY_EVIDENCE=12
# CONCURRENCY_ANALYZER=10
# CONCURRENCY_RELEVANCE=14
# CONCURRENCY_VERIFIER=14

# ---- Deep research harvest budget ----
# Defaults target a real deep-research corpus, not a quick demo.
# HARVEST_BREADTH=8
# HARVEST_DEPTH=2
# HARVEST_PAGES_PER_QUERY=3
# HARVEST_URLS_PER_QUERY=10
# HARVEST_READ_CONCURRENCY=6
# MAX_HARVEST_MINUTES=90
# MAX_HARVEST_SOURCES=400
# SNOWBALL_MAX_PAPERS=8

# Optional fallback endpoints for multi-endpoint failover:
# QWEN_FALLBACK_URLS=https://backup-1/v1,https://backup-2/v1

# SearXNG service URL on the compose network.
SEARXNG_URL=http://research-lab-searxng:8080
PIPELINE_SEARXNG_URL=http://research-lab-searxng:8080

# ---- Pipeline container paths ----
# Host-side repo root. The web container spawns pipeline containers via
# docker-out-of-docker; the bind mount must be a HOST path.
PIPELINE_HOST_REPO_ROOT=/opt/research-lab
# Compose network the pipeline container attaches to — usually
# "<project_dir>_default" (project dir is the deploy/ folder name).
PIPELINE_NETWORK=deploy_default

# ---- Docker socket group ----
# The web container's `app` user needs this supplementary GID to read
# /var/run/docker.sock on the host. Check with:
#   stat -c %g /var/run/docker.sock
DOCKER_GID=988
